{
  "$schema": "cascade-control-sandbox/ia2_config/v1",
  "project": "cascade_control_sandbox",
  "description": "Register <-> engineering-variable map for the 3-tank decoupled process. This is the single contract shared by mock_cabinet.py (encoder), the IA2 Modbus iomap (ia2_project/), and aio_bridge_env.py (decoder). engineering_value = raw_register * scale.",

  "modbus": {
    "transport": "tcp",
    "host": "127.0.0.1",
    "port": 5020,
    "unit_id": 1,
    "timeout_s": 2.0,
    "byte_order": "big",
    "word_order": "big"
  },

  "ia2": {
    "server_url": "http://127.0.0.1:3001",
    "health_path": "/api/health",
    "project_name": "cascade_control_sandbox",
    "application_pou": "ThreeTank",
    "device_name": "mock_cabinet"
  },

  "registers": [
    {
      "name": "tank1_level", "plc": 40001, "address": 0, "table": "holding",
      "type": "uint16", "units": "m", "scale": 0.0001,
      "min": 0.0, "max": 0.60, "direction": "read", "group": "tank1",
      "ia2_variable": "ThreeTank.tank1_level"
    },
    {
      "name": "tank1_temp", "plc": 40002, "address": 1, "table": "holding",
      "type": "uint16", "units": "degC", "scale": 0.01,
      "min": 0.0, "max": 100.0, "direction": "read", "group": "tank1",
      "ia2_variable": "ThreeTank.tank1_temp"
    },
    {
      "name": "tank2_level", "plc": 40003, "address": 2, "table": "holding",
      "type": "uint16", "units": "m", "scale": 0.0001,
      "min": 0.0, "max": 0.60, "direction": "read", "group": "tank2",
      "ia2_variable": "ThreeTank.tank2_level"
    },
    {
      "name": "tank2_temp", "plc": 40004, "address": 3, "table": "holding",
      "type": "uint16", "units": "degC", "scale": 0.01,
      "min": 0.0, "max": 100.0, "direction": "read", "group": "tank2",
      "ia2_variable": "ThreeTank.tank2_temp"
    },
    {
      "name": "tank3_level", "plc": 40005, "address": 4, "table": "holding",
      "type": "uint16", "units": "m", "scale": 0.0001,
      "min": 0.0, "max": 0.60, "direction": "read", "group": "tank3_decoupled",
      "ia2_variable": "ThreeTank.tank3_level"
    },
    {
      "name": "tank3_temp", "plc": 40006, "address": 5, "table": "holding",
      "type": "uint16", "units": "degC", "scale": 0.01,
      "min": 0.0, "max": 100.0, "direction": "read", "group": "tank3_decoupled",
      "ia2_variable": "ThreeTank.tank3_temp"
    },
    {
      "name": "actuator1", "plc": 40007, "address": 6, "table": "holding",
      "type": "uint16", "units": "fraction", "scale": 0.0001,
      "min": 0.0, "max": 1.0, "direction": "write", "group": "actuators",
      "physical": "pump1_flow_fraction", "ia2_variable": "ThreeTank.actuator1"
    },
    {
      "name": "actuator2", "plc": 40008, "address": 7, "table": "holding",
      "type": "uint16", "units": "fraction", "scale": 0.0001,
      "min": 0.0, "max": 1.0, "direction": "write", "group": "actuators",
      "physical": "pump2_flow_fraction", "ia2_variable": "ThreeTank.actuator2"
    },
    {
      "name": "reset_cmd", "plc": 40009, "address": 8, "table": "holding",
      "type": "uint16", "units": "nonce", "scale": 1.0,
      "min": 0.0, "max": 65535.0, "direction": "write", "group": "reset",
      "ia2_variable": "ThreeTank.reset_cmd"
    },
    {
      "name": "init_h1", "plc": 40010, "address": 9, "table": "holding",
      "type": "uint16", "units": "m", "scale": 0.0001,
      "min": 0.0, "max": 0.60, "direction": "write", "group": "reset",
      "ia2_variable": "ThreeTank.init_h1"
    },
    {
      "name": "init_h2", "plc": 40011, "address": 10, "table": "holding",
      "type": "uint16", "units": "m", "scale": 0.0001,
      "min": 0.0, "max": 0.60, "direction": "write", "group": "reset",
      "ia2_variable": "ThreeTank.init_h2"
    },
    {
      "name": "init_h3", "plc": 40012, "address": 11, "table": "holding",
      "type": "uint16", "units": "m", "scale": 0.0001,
      "min": 0.0, "max": 0.60, "direction": "write", "group": "reset",
      "ia2_variable": "ThreeTank.init_h3"
    },
    {
      "name": "heater1", "plc": 40013, "address": 12, "table": "holding",
      "type": "uint16", "units": "fraction", "scale": 0.0001,
      "min": 0.0, "max": 1.0, "direction": "write", "group": "heaters",
      "physical": "heater1_ssr_duty", "ia2_variable": "ThreeTank.heater1"
    },
    {
      "name": "heater2", "plc": 40014, "address": 13, "table": "holding",
      "type": "uint16", "units": "fraction", "scale": 0.0001,
      "min": 0.0, "max": 1.0, "direction": "write", "group": "heaters",
      "physical": "heater2_ssr_duty", "ia2_variable": "ThreeTank.heater2"
    },
    {
      "name": "heater3", "plc": 40015, "address": 14, "table": "holding",
      "type": "uint16", "units": "fraction", "scale": 0.0001,
      "min": 0.0, "max": 1.0, "direction": "write", "group": "heaters",
      "physical": "heater3_ssr_duty", "ia2_variable": "ThreeTank.heater3"
    }
  ],

  "sensors": [
    "tank1_level", "tank1_temp",
    "tank2_level", "tank2_temp",
    "tank3_level", "tank3_temp"
  ],
  "actuators": ["actuator1", "actuator2", "heater1", "heater2", "heater3"],

  "reset": {
    "command_register": "reset_cmd",
    "init_levels": ["init_h1", "init_h2", "init_h3"],
    "init_level_range_m": [0.10, 0.50],
    "mechanism": "value-change: env writes a fresh nonzero nonce to reset_cmd each reset; cabinet snaps state to init_h* on any change and HOLDS while reset_cmd != 0; writing 0 resumes stepping"
  },

  "process": {
    "q_max_m3s": 0.0002,
    "h_max_m": 0.60,
    "t_supply_c": 20.0,
    "topology": "tank1 --a1--> tank2 --a3--> tank3 ; pump1->tank1, pump2->tank3, tank2->drain",
    "cp_j_per_kgk": 4180.0,
    "rho_kg_per_m3": 1000.0,
    "q_heat_max_w": 25000.0,
    "ua_w_per_k": 8.0,
    "t_ambient_c": 20.0,
    "_heater_note": "Q_heat_max is tuned for a controllable problem, not physically scaled: the tank turnover (q/V) is fast, so the heater must be large to hold temp against the cold supply inflow."
  },

  "control": {
    "setpoints_m": {
      "tank1_level": 0.45,
      "tank2_level": 0.30,
      "tank3_level": 0.40
    },
    "setpoints_c": {
      "tank1_temp": 45.0,
      "tank2_temp": 45.0,
      "tank3_temp": 45.0
    },
    "objective": "Cascade / decoupling control: hold Tank1/Tank3 levels AND all three temperatures at setpoint despite hydraulic coupling through Tank2 and the level->thermal-mass coupling (fuller tank = slower to heat).",
    "reward": "-(w_level*sum((level_i-sp)^2) + w_temp*sum((temp_i-Tsp)^2) + w_action*sum(action)) per step (maximize)",
    "reward_weights": {"level": 1.0, "temp": 0.002, "action": 0.01}
  },

  "timing": {
    "modbus_poll_ms": 50,
    "plc_scan_ms": 50,
    "snapshot_broadcast_hz": 10,
    "obs_lag_ms_est": 200,
    "min_control_dt_s": 0.3,
    "note": "Observations are read from the runtime snapshot (~10 Hz broadcast cache), on top of the 50 ms Modbus poll and the 50 ms PLC scan, so expect up to ~200 ms of observation lag. Fine at control_dt >= 0.3 s; do not shrink control_dt below the lag budget."
  }
}
